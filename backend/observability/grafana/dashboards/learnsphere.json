{
    "title": "LearnSphere KPIs (Complete)",
    "tags": [
        "learnsphere",
        "kpi"
    ],
    "timezone": "",
    "editable": true,
    "graphTooltip": 1,
    "refresh": "5s",
    "time": {
        "from": "now-15m",
        "to": "now"
    },
    "schemaVersion": 39,
    "version": 1,
    "panels": [
        {
            "type": "table",
            "title": "Latency p95 by route (last 5m)",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "options": {
                "showHeader": true,
                "footer": {
                    "show": false,
                    "fields": "",
                    "reducer": [
                        "sum"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green"
                            },
                            {
                                "value": 0.01,
                                "color": "red"
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.95, sum by (le,route)(rate(ls_http_request_seconds_bucket[5m])))",
                    "legendFormat": "{{route}}"
                }
            ],
            "transformations": [
                {
                    "id": "seriesToColumns",
                    "options": {
                        "byField": "Time"
                    }
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Requests/sec by route (1m rate)",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "req/s"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "right"
                },
                "tooltip": {
                    "mode": "single"
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (route,method,code)(rate(ls_http_requests_total[1m]))",
                    "legendFormat": "{{route}} {{method}} {{code}}"
                }
            ]
        },
        {
            "type": "stat",
            "title": "Avg TTFR by client (Unity)",
            "gridPos": {
                "h": 6,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "orientation": "horizontal",
                "colorMode": "value"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green"
                            },
                            {
                                "value": 2,
                                "color": "yellow"
                            },
                            {
                                "value": 4,
                                "color": "red"
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (client_id)(ls_client_ttfr_seconds_sum) / sum by (client_id)(ls_client_ttfr_seconds_count)",
                    "legendFormat": "{{client_id}}"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Latest FPS by client",
            "gridPos": {
                "h": 6,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "fps",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red"
                            },
                            {
                                "value": 60,
                                "color": "yellow"
                            },
                            {
                                "value": 72,
                                "color": "green"
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "avg by (client_id)(ls_client_fps)",
                    "legendFormat": "{{client_id}}"
                }
            ]
        },
        {
            "type": "stat",
            "title": "Total GB served (assets, current range)",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 0,
                "y": 14
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "orientation": "horizontal",
                "colorMode": "value"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green"
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum(increase(ls_http_response_bytes_total{route=~\"/assets/.+\",method=\"GET\"}[$__range])) / 1e9",
                    "legendFormat": "GB"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Throughput MB/s (assets, 1m rate)",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 6,
                "y": 14
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "right"
                },
                "tooltip": {
                    "mode": "single"
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum(rate(ls_http_response_bytes_total{route=~\"/assets/.+\",method=\"GET\"}[1m])) / 1e6",
                    "legendFormat": "MB/s"
                }
            ]
        },
        {
            "type": "bargauge",
            "title": "GB by extension (assets, $__interval)",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 12,
                "y": 14
            },
            "options": {
                "displayMode": "basic"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green"
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (ext)(increase(ls_http_response_bytes_total{route=~\"/assets/.+\",method=\"GET\"}[$__interval])) / 1e9",
                    "legendFormat": "{{ext}}"
                }
            ]
        },
        {
            "type": "table",
            "title": "Top files by GB (assets, current range)",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 18,
                "y": 14
            },
            "options": {
                "showHeader": true
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                },
                "overrides": []
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "topk(10, sum by (route)(increase(ls_http_response_bytes_total{route=~\"/assets/.+\",method=\"GET\"}[$__range]))) / 1e9",
                    "legendFormat": "{{route}}"
                }
            ],
            "transformations": [
                {
                    "id": "seriesToColumns",
                    "options": {
                        "byField": "Time"
                    }
                }
            ]
        }
    ],
    "templating": {
        "list": []
    }
}