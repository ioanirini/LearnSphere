# Get latest base template from https://github.com/github/gitignore/blob/main/Unity.gitignore

# --- Unity generated folders ---
/LS-Unity/[Ll]ibrary/
/LS-Unity/[Tt]emp/
/LS-Unity/[Oo]bj/
/LS-Unity/[Bb]uild*/
/LS-Unity/[Ll]ogs/
/LS-Unity/[Uu]ser[Ss]ettings/
/LS-Unity/[Mm]emoryCaptures/
/LS-Unity/[Rr]ecordings/

# --- IDE / Tool specific ---
/LS-Unity/.vs/
/LS-Unity/.gradle/
/LS-Unity/[Aa]ssets/Plugins/Editor/JetBrains*
/LS-Unity/*.DotSettings.user

# --- Logs ---
*.log

# --- Blender ---
*.blend1
*.blend1.meta

# --- Mono / Crash ---
mono_crash.*
sysinfo.txt
crashlytics-build.properties

# --- Build outputs ---
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# --- Unity project files ---
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# --- Meta files generated for the above ---
*.pidb.meta
*.pdb.meta
*.mdb.meta

# --- Addressables ---
/LS-Unity/ServerData/
/LS-Unity/[Aa]ssets/StreamingAssets/aa*
/LS-Unity/[Aa]ssets/AddressableAssetsData/link.xml*
/LS-Unity/[Aa]ssets/Addressables_Temp*
/LS-Unity/[Aa]ssets/AddressableAssetsData/*/*.bin*

# --- Visual Scripting generated data ---
/LS-Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db*
/LS-Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers*

# --- Auto-generated test scenes ---
/LS-Unity/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
